{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureVault Ultimate",
  "version": "0.1.0",
  "identifier": "com.securevault.ultimate",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SecureVault Ultimate",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "publisher": "SecureVault",
    "shortDescription": "Zero-knowledge encrypted vault",
    "longDescription": "A zero-knowledge encrypted vault with directory flattening, encrypted indexes, chunked AES-GCM storage, and local defense checks.",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "sidebarImage": "installer-assets/sidebar.bmp",
        "headerImage": "installer-assets/header.bmp",
        "installerHooks": "nsis-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhCRTNFQTREQjBGMkQ3NEUKUldSTzEvS3dUZXJqaSs3WXFYTmhxT3UzWWxyUktpaFVKQzZKZUxVZGMrcnRPVjY0dGN2LzRKUE0K",
      "endpoints": [
        "https://github.com/scarl/SecureVaultUltimate/releases/latest/download/updater.json"
      ]
    }
  }
}
